pipeline {
    agent any
    
    environment {
        LANG = "en_US.UTF-8"
        LC_ALL = "en_US.UTF-8"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install dependencies') {
            steps {
                dir('SelfOSLab') {
                    sh '''
                        export PATH="$HOME/.rbenv/bin:$HOME/.rbenv/shims:/opt/homebrew/bin:$PATH"
                            
                        gem install bundler
                        bundle install
                    '''
                }
            }
        }
        
        stage('Match AppStore signing') {
            steps {
                dir('SelfOSLab') {
                    sh '''
                        export PATH="$HOME/.rbenv/bin:$HOME/.rbenv/shims:/opt/homebrew/bin:$PATH"
                        bundle exec fastlane ios match_appstore
                    '''
                }
            }
        }
        
        stage('Build') {
            steps {
                dir('SelfOSLab') {
                    sh '''
                        export PATH="$HOME/.rbenv/bin:$HOME/.rbenv/shims:/opt/homebrew/bin:$PATH"
                        bundle exec fastlane ios build_appstore
                    '''
                }
            }
        }
        
        stage('Upload to TestFlight') {
            steps {
                dir('SelfOSLab') {
                    withCredentials([
                        file(credentialsId: 'appstore-key', variable: 'APPSTORE_KEY_FILE'),
                        string(credentialsId: 'appstore-key-id', variable: 'APPSTORE_KEY_ID'),
                        string(credentialsId: 'appstore-issuer-id', variable: 'APPSTORE_ISSUER_ID')
                    ]) {
                        sh '''
                            export PATH="$HOME/.rbenv/bin:$HOME/.rbenv/shims:/opt/homebrew/bin:$PATH"
                            
                            # Fastlane env
                            export APPSTORE_KEY_FILE=$APPSTORE_KEY_FILE
                            export APPSTORE_KEY_ID=$APPSTORE_KEY_ID
                            export APPSTORE_ISSUER_ID=$APPSTORE_ISSUER_ID
                            bundle exec fastlane ios upload_testflight
                        '''
                    }
                }
            }
        }
    }
    
    post {
        success {
            echo "🚀 Build successful — uploaded to TestFlight"
        }
        failure {
            echo "❌ Build failed"
        }
    }
}
