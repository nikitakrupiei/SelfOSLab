default_platform(:ios)

platform :ios do

  desc "Run CI tests"
  lane :tests_ci do
    generate
    tests
  end

  desc "Generate project using Tuist"
  lane :generate do
    Dir.chdir("SelfOSLab") do
      sh("tuist generate")
    end
  end

  desc "Run unit tests"
  lane :tests do
    Dir.chdir("SelfOSLab") do
      sh("tuist test")
    end
  end

end
