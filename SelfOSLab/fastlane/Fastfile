default_platform(:ios)

platform :ios do

  desc "Run CI tests"
  lane :tests_ci do
    generate
    tests
  end

  desc "Generate project using Tuist"
  lane :generate do
    project_root = File.expand_path("..", Dir.pwd)

    Dir.chdir(project_root) do
      sh("tuist generate")
    end
  end

  desc "Run unit tests"
  lane :tests do
    project_root = File.expand_path("..", Dir.pwd)
    
    Dir.chdir(project_root) do
      sh("tuist test --result-bundle-path result.xcresult")
      
      # конвертація в JUnit
      sh("xcresultparser --output junit.xml result.xcresult")
    end
  end

end
