pipeline {
    agent any
    
    environment {
        LANG = "en_US.UTF-8"
        LC_ALL = "en_US.UTF-8"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install dependencies') {
            steps {
                dir('SelfOSLab') {
                    sh '''
                        export PATH="$HOME/.rbenv/bin:$HOME/.rbenv/shims:/opt/homebrew/bin:$PATH"
                        
                        gem install bundler
                        bundle install
                    '''
                }
            }
        }

        stage('Tests') {
            steps {
                dir('SelfOSLab') {
                    sh '''
                        export PATH="$HOME/.rbenv/bin:$HOME/.rbenv/shims:/opt/homebrew/bin:$PATH"
                        
                        bundle exec fastlane tests_ci
                    '''
                }
            }
        }
        
        stage('Prepare artifacts') {
            steps {
                sh '''
                    cd SelfOSLab
                    zip -r testResult.zip testResult.xcresult
                '''
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'SelfOSLab/testResult.zip', fingerprint: true
        }
    }
}
