pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install dependencies') {
            steps {
                    sh '''
                        export PATH="$HOME/.rbenv/bin:$HOME/.rbenv/shims:/opt/homebrew/bin:$PATH"

                        which ruby
                        ruby -v

                        which tuist
                        tuist version

                        gem install bundler
                        bundle install
                    '''
                }
        }

        stage('Tests') {
            steps {
                    sh '''
                        export PATH="$HOME/.rbenv/bin:$HOME/.rbenv/shims:/opt/homebrew/bin:$PATH"

                        which ruby
                        ruby -v

                        which tuist
                        tuist version

                        bundle exec fastlane tests_ci
                    '''
                }
        }
    }
}
