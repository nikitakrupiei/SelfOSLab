pipeline {
    agent any
    
    environment {
        LANG = "en_US.UTF-8"
        LC_ALL = "en_US.UTF-8"
    }

    stages {
	stage('Setup environment') {
	    steps {
        	sh '''
            	export PATH="$HOME/.rbenv/bin:$PATH"
            	eval "$(rbenv init - bash)"
            	rbenv global 3.2.2

            	ruby -v
        	'''
    	    }
	}
	
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install dependencies') {
            steps {
                dir('SelfOSLab') {
                    sh '''
                        export PATH="$HOME/.rbenv/bin:$HOME/.rbenv/shims:/opt/homebrew/bin:$PATH"
                        
                        gem install bundler
                        bundle install
                    '''
                }
            }
        }
        
        stage('Generate project') {
            steps {
                dir('SelfOSLab') {
                    sh '''
                        bundle exec fastlane generate
                    '''
                }
            }
        }

        stage('Tests') {
            steps {
                dir('SelfOSLab') {
                    sh '''
                        export PATH="$HOME/.rbenv/bin:$HOME/.rbenv/shims:/opt/homebrew/bin:$PATH"
                        
                        bundle exec fastlane tests
                    '''
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'SelfOSLab/testResult.xcresult/**', fingerprint: true
        }
    }
}
